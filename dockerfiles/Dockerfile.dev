FROM node:20-alpine

WORKDIR /app

# Copy package files and install all dependencies
COPY package*.json ./
RUN npm install

# Source code is mounted as a volume at runtime (see docker-compose.yml)
# The node_modules volume excludes the host's node_modules

# Expose Express backend and Vite dev server ports
EXPOSE 5000
EXPOSE 5173

CMD ["npm", "run", "dev"]